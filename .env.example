# Copy this file to .env and adjust as needed.
# Connection string for the application's PostgreSQL database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_tasks

# Connection string used by the test suite (a separate, disposable database).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_tasks_test

# Application environment: development or production.
# In production, SECRET_KEY must not be the default dev value and /docs is disabled.
APP_ENV=development

# JWT authentication settings.
# Generate a strong secret, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`.
SECRET_KEY=dev-secret-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated list of browser origins allowed to call the API (CORS).
# Example (frontend dev server): http://localhost:5173
# In production, include your deployed frontend URL, e.g.
# https://student-task-frontend.onrender.com,http://localhost:5173
CORS_ORIGINS=http://localhost:5173
