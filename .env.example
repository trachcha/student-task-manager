# Copy this file to .env and adjust as needed.
# Connection string for the application's PostgreSQL database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_tasks

# Connection string used by the test suite (a separate, disposable database).
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_tasks_test

# JWT authentication settings.
# Generate a strong secret, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`.
SECRET_KEY=dev-secret-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
